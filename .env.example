# LLM Provider — choose "groq" (free) or "anthropic"
LLM__PROVIDER=groq

# Groq — free tier at console.groq.com (no credit card required)
LLM__GROQ__APIKEY=gsk_...
LLM__GROQ__MODEL=llama-3.3-70b-versatile

# Anthropic — optional, higher quality (~$0.50 USD total for the lab)
LLM__ANTHROPIC__APIKEY=sk-ant-...
LLM__ANTHROPIC__MODEL=claude-haiku-4-5-20251001

# ASR (Whisper.cpp) — set automatically by Aspire in dev, override for Docker-only mode
# WHISPER__BASEURL=http://localhost:8081

# TTS (Kokoro) — set automatically by Aspire in dev, override for Docker-only mode
# KOKORO__BASEURL=http://localhost:3000

# Observability — set automatically by Aspire in dev, override for Docker-only mode
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
